# Datos que GitHub te da al crear la App
GH_APP_ID=000000
GH_PRIVATE_KEY_PATH=./secrets/avantdef.private-key.pem
GH_WEBHOOK_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# Puerto del servicio
PORT=4100

# (Opcional) clave compartida que tu backend Node debe enviar en X-Internal-Token
# para autenticar las llamadas a /propose. Sin esto, el endpoint queda abierto.
INTERNAL_TOKEN=
